{
  "id": null,
  "uid": "zhytomate-rag",
  "title": "Zhytomate RAG",
  "tags": ["zhytomate", "rag"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP latency p50 / p95",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_highr_seconds_bucket[5m])))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_highr_seconds_bucket[5m])))", "legendFormat": "p95"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "LLM latency p95",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(zhytomate_llm_latency_seconds_bucket[5m])))", "legendFormat": "p95"}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Empty retrieval rate",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "rate(zhytomate_retrieval_empty_total[15m])", "legendFormat": "empty/s"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Classification cache hit rate",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(zhytomate_classification_cache_hits_total[15m])) / clamp_min(sum(rate(zhytomate_classification_cache_lookups_total[15m])), 1)", "legendFormat": "hit ratio"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "RAG queries / minute",
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(http_request_duration_seconds_count{handler=~\"/api/v1/(assistant|chat).*\"}[5m])) * 60", "legendFormat": "queries/min"}],
      "fieldConfig": {"defaults": {"unit": "reqpm"}, "overrides": []}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Degraded responses / hour",
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(increase(zhytomate_degraded_responses_total[1h]))", "legendFormat": "fallbacks"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Unmapped districts / hour",
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(increase(zhytomate_district_unmapped_total[1h]))", "legendFormat": "unmapped"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    }
  ]
}
