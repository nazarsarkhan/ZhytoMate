# Leave VITE_API_BASE_URL unset for normal Vite dev: requests go to /api and Vite proxies them.
# Set it when the frontend is served without the dev proxy, for example:
# VITE_API_BASE_URL=http://localhost:3000/api

# Local Docker on this machine publishes backend on 3001; use 3000 with the unmodified base compose file.
VITE_API_PROXY_TARGET=http://localhost:3001
