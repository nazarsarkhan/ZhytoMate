# .env.example — template of env vars with NO real values (copy to .env locally).
# .env itself is git-ignored and never committed (docs/SYSTEM_DESIGN.md §8).

# Postgres credentials consumed by docker-compose.yml's env-var interpolation. Keep these
# three in sync with the connection string encoded in DATABASE_URL below — the same
# credentials are duplicated in two places, and drifting one without the other breaks the
# ml service's ability to connect to its own postgres container.
POSTGRES_USER=zhytomate
POSTGRES_PASSWORD=secret
POSTGRES_DB=zhytomate

DATABASE_URL=postgresql://zhytomate:secret@postgres:5432/zhytomate
OPENAI_API_KEY=your-openai-api-key-here
INTERNAL_TOKEN=change-me-to-a-random-secret

LLM_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-large

# RAG thresholds — PROVISIONAL placeholders for the NEW embedding space.
# MUST re-run scripts/calibrate_thresholds.py — old e5-calibrated values are invalid.
SIM_GATE=0.70
SIM_HIGH=0.80

RATE_LIMIT_PER_MINUTE=10
AGENT_RAG_ENABLED=false
AGENT_MAX_SUBQUERIES=3
ANSWER_CACHE_TTL_SECONDS=120
ANSWER_CACHE_MAXSIZE=200
EMBED_CACHE_MAXSIZE=1000
RRF_K=60
