# .env.example — template of env vars with NO real values (copy to .env locally).
# .env itself is git-ignored and never committed (docs/SYSTEM_DESIGN.md §8).

# Required — no defaults, the service fails fast without these.
DATABASE_URL=postgresql://zhytomate:secret@postgres:5432/zhytomate
GEMINI_API_KEY=your-gemini-api-key-here
INTERNAL_TOKEN=change-me-to-a-random-secret
# Hosted-LLM model id — env only, never a committed value (put your model id here).
GEMINI_MODEL=your-model-id-here

# Model (open-source default; override only if needed).
EMBED_MODEL=intfloat/multilingual-e5-base

# RAG thresholds — PROVISIONAL, calibrate before the demo (scripts/calibrate_thresholds.py).
SIM_GATE=0.78
SIM_HIGH=0.85

# Rate limiting.
RATE_LIMIT_PER_MINUTE=10

# Feature flags.
AGENT_RAG_ENABLED=false

# Performance.
TORCH_NUM_THREADS=4
ANSWER_CACHE_TTL_SECONDS=120
ANSWER_CACHE_MAXSIZE=200
RRF_K=60
