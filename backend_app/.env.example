PORT=3000
NODE_ENV=development

MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/zhytomate?retryWrites=true&w=majority

JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ml-service (FastAPI RAG + vision) — internal, never exposed to the browser.
ML_BASE_URL=http://localhost:8000
# Must exactly match ml-service/.env's INTERNAL_TOKEN — both sides authenticate with the same secret.
INTERNAL_TOKEN=change_me_to_match_ml_service_internal_token

# Comma-separated allowlist of origins allowed to call this API cross-origin. In dev, Vite's own
# proxy (vite.config.js) makes the browser's requests same-origin, so this mostly matters if the
# frontend is ever pointed directly at this server from a different origin.
CORS_ORIGINS=http://localhost:5173
