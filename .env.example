# .env.example (repo root) — copy to .env. Governs `docker compose up` from the repo root,
# which brings up the WHOLE stack (Postgres, ml-service, MongoDB, backend_app, frontend_app,
# and optionally parser). Independent of ml-service/.env and backend_app/.env, which still
# govern their own standalone (non-Docker) dev workflows unchanged - values may be copied
# between them for convenience, but there's no hard requirement they match.
#
# A single INTERNAL_TOKEN here, substituted into both `ml`'s and `backend`'s (and `parser`'s)
# environment blocks, is what guarantees the three can never drift out of sync the way three
# separately-maintained .env files could.

# --- Shared service-to-service secret (ml <-> backend <-> parser) ---
INTERNAL_TOKEN=change-me-to-a-random-secret

# --- Postgres (postgres + ml services) ---
POSTGRES_USER=zhytomate
POSTGRES_PASSWORD=secret
POSTGRES_DB=zhytomate

# --- ml (FastAPI RAG + vision) ---
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-large
# Calibrated on the seeded KB (see ml-service/CLAUDE.md) - do not revert to 0.70/0.80.
SIM_GATE=0.50
SIM_HIGH=0.62
RATE_LIMIT_PER_MINUTE=10
AGENT_RAG_ENABLED=false
AGENT_MAX_SUBQUERIES=3
ANSWER_CACHE_TTL_SECONDS=120
ANSWER_CACHE_MAXSIZE=200
EMBED_CACHE_MAXSIZE=1000
RRF_K=60

# --- backend (Express) ---
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000

# --- parser (only used with `docker compose --profile collector up`) ---
# TG_SESSION must be generated once, out-of-band, via `cd parser && npm run session`
# (interactive) on a real machine - leave blank if you never run the collector profile.
TG_API_ID=
TG_API_HASH=
TG_SESSION=
